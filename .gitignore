# Rust
target/
Cargo.lock.bak
**/*.rs.bk

# wasm-pack intermediate output (we DO commit web/public/pkg/ as a built
# artifact so that the Svelte frontend and GitHub Pages deploys don't need
# a Rust toolchain to produce a working build)
crates/**/pkg/
wasm-pack.log

# Node
node_modules/
dist/
.vite/
*.tsbuildinfo

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Local env
.env
.env.local

# Local MCP server config (user-specific browser automation)
.mcp.json

# Vite + Node
web/node_modules/
web/dist/
web/.vite/

# Playwright test output — HTML report, traces, screenshots, videos.
# Generated on every test run and never committed.
web/playwright-report/
web/test-results/
web/blob-report/
web/playwright/.cache/

# .tmp/ — deferred-work prompt files for future sessions. Local-only.
.tmp/
